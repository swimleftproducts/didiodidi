{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://didiodidi.com/schema/snapshot/v1.json",
  "title": "didiodidi snapshot payload",
  "description": "Wire contract between the Flutter app and the /ingest serverless function. schema_version 1.",
  "type": "object",
  "required": ["schema_version", "username", "slug", "generated_at", "window", "stats", "days"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "username": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,32}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z2-7]{10}$"
    },
    "generated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "window": {
      "type": "object",
      "required": ["start", "end"],
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "end": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "stats": {
      "type": "object",
      "required": ["completed", "total"],
      "additionalProperties": false,
      "properties": {
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "days": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/day"
      }
    }
  },
  "$defs": {
    "day": {
      "type": "object",
      "required": ["date", "weekday", "tasks"],
      "additionalProperties": false,
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "weekday": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "required": ["id", "title", "description", "completed"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "completed": {
          "type": "boolean"
        },
        "image": {
          "type": "string",
          "pattern": "^data:image/(png|jpeg|webp);base64,"
        }
      }
    }
  }
}
